{
  "name": "accessscan",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "db:generate": "pnpm --filter @accessscan/db prisma generate",
    "db:migrate": "pnpm --filter @accessscan/db prisma migrate dev",
    "db:migrate:test": "dotenv -e .env.test -- pnpm --filter @accessscan/db prisma migrate deploy",
    "db:seed": "dotenv -e .env -- pnpm --filter @accessscan/db exec tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0",
    "dotenv-cli": "^7.4.0",
    "dotenv": "^16.4.0",
    "@types/node": "^20.16.0"
  }
}
