DATABASE_URL="postgresql://accessscan:accessscan@localhost:5432/accessscan?schema=public"
REDIS_URL="redis://localhost:6379"
AUTH_SECRET="change-me-32-bytes-min"
# Master key for the credential vault. MUST base64-decode to exactly 32 bytes.
# Generate a real one: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
VAULT_MASTER_KEY="REPLACE_ME_base64_of_32_random_bytes"
